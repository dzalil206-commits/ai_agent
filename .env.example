# Токен бота от @BotFather
BOT_TOKEN=ВСТАВЬ_СЮДА_ТОКЕН_ОТ_BOTFATHER

# Имя файла базы данных
DB_PATH=bot.db

# --- ИИ (Claude API) ---
# Ключ из консоли Anthropic (sk-ant-...) или от реселлера. Пусто = ИИ отключён.
ANTHROPIC_API_KEY=ВСТАВЬ_СЮДА_КЛЮЧ_ANTHROPIC

# Адрес API. Для официального ключа Anthropic (sk-ant-...) — оставь пустым.
# Для ключа от реселлера aiprimetech.io — вставь адрес реселлера:
ANTHROPIC_BASE_URL=https://api.aiprimetech.io/v1

# Модель. aiprimetech поддерживает: claude-3-5-sonnet-20241022, claude-3-sonnet-20240229 и др.
AI_MODEL=claude-3-5-sonnet-20241022

# Максимум токенов в одном ответе ИИ
AI_MAX_TOKENS=2000

# Лимит ИИ-запросов на пользователя в день
AI_DAILY_LIMIT=50
