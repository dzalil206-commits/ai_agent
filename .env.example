# Токен бота от @BotFather
BOT_TOKEN=ВСТАВЬ_СЮДА_ТОКЕН_ОТ_BOTFATHER

# Имя файла базы данных
DB_PATH=bot.db

# --- ИИ (Claude API) ---
# Ключ из консоли Anthropic (sk-ant-...) или от реселлера. Пусто = ИИ отключён.
ANTHROPIC_API_KEY=ВСТАВЬ_СЮДА_КЛЮЧ_ANTHROPIC

# Адрес API. Для официального ключа Anthropic — оставь пустым.
# Для ключа от реселлера — впиши адрес из его документации, например:
# ANTHROPIC_BASE_URL=https://api.proxyapi.ru/anthropic
ANTHROPIC_BASE_URL=

# Модель (можно не трогать)
AI_MODEL=claude-opus-4-8

# Максимум токенов в одном ответе ИИ
AI_MAX_TOKENS=2000

# Лимит ИИ-запросов на пользователя в день
AI_DAILY_LIMIT=50
